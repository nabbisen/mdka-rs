{
  "name": "mdka",
  "version": "2.0.0-rc.4",
  "description": "省メモリ・高速なHTML to Markdownコンバータ (Rust製) のNode.jsバインディング",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "Apache-2.0",
  "keywords": [
    "html",
    "markdown",
    "html2md",
    "converter",
    "napi",
    "rust"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "name": "mdka",
    "triples": {
      "defaults": true
    }
  },
  "scripts": {
    "build": "napi build --platform --release --js index.js --dts index.d.ts",
    "test": "node test.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "engines": {
    "node": ">= 16"
  }
}